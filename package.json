{
  "name": "cpp-smart-runner",
  "displayName": "C/C++ Smart Runner",
  "description": "安全地編譯和執行 C/C++ 程式，具備檔案時間戳記檢查和自動編碼轉換功能",
  "version": "1.1.5",
  "publisher": "hueyanchen",
  "author": {
    "name": "Hueyan Chen",
    "email": "hueyan.chen@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "c",
    "c++",
    "cpp",
    "compile",
    "run",
    "gcc",
    "g++",
    "encoding",
    "utf8",
    "big5",
    "dev-c++"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/code4Copilot/cpp-smart-runner.git"
  },
  "bugs": {
    "url": "https://github.com/code4Copilot/cpp-smart-runner/issues"
  },
  "homepage": "https://github.com/code4Copilot/cpp-smart-runner#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cpp-smart-runner.compile",
        "title": "編譯C/C++程式",
        "icon": "$(tools)"
      },
      {
        "command": "cpp-smart-runner.run",
        "title": "執行C/C++程式",
        "icon": "$(play)"
      },
      {
        "command": "cpp-smart-runner.compileAndRun",
        "title": "編譯並執行C/C++程式",
        "icon": "$(run-all)"
      },
      {
        "command": "cpp-smart-runner.convertToUtf8",
        "title": "轉換為 UTF-8 (自動偵測)",
        "icon": "$(symbol-text)"
      },
      {
        "command": "cpp-smart-runner.convertFromBig5",
        "title": "從 Big5 轉換為 UTF-8",
        "icon": "$(symbol-text)"
      },
      {
        "command": "cpp-smart-runner.convertFromGbk",
        "title": "從 GBK 轉換為 UTF-8",
        "icon": "$(symbol-text)"
      },
      {
        "command": "cpp-smart-runner.convertToBig5",
        "title": "轉換為 Big5 編碼",
        "icon": "$(symbol-text)"
      }
    ],
    "keybindings": [
      {
        "command": "cpp-smart-runner.compile",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorLangId == c || editorLangId == cpp"
      },
      {
        "command": "cpp-smart-runner.run",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorLangId == c || editorLangId == cpp"
      },
      {
        "command": "cpp-smart-runner.compileAndRun",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorLangId == c || editorLangId == cpp"
      }
    ],
    "submenus": [
      {
        "id": "cpp-smart-runner.encodingMenu",
        "label": "轉換編碼",
        "icon": "$(symbol-text)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == c || resourceLangId == cpp",
          "command": "cpp-smart-runner.compile",
          "group": "navigation@90"
        },
        {
          "when": "resourceLangId == c || resourceLangId == cpp",
          "command": "cpp-smart-runner.run",
          "group": "navigation@91"
        },
        {
          "when": "resourceLangId == c || resourceLangId == cpp",
          "command": "cpp-smart-runner.compileAndRun",
          "group": "navigation@92"
        },
        {
          "when": "resourceLangId == c || resourceLangId == cpp",
          "submenu": "cpp-smart-runner.encodingMenu",
          "group": "navigation@93"
        }
      ],
      "cpp-smart-runner.encodingMenu": [
        {
          "command": "cpp-smart-runner.convertToUtf8",
          "group": "1_utf8@1"
        },
        {
          "command": "cpp-smart-runner.convertFromBig5",
          "group": "1_utf8@2"
        },
        {
          "command": "cpp-smart-runner.convertFromGbk",
          "group": "1_utf8@3"
        },
        {
          "command": "cpp-smart-runner.convertToBig5",
          "group": "2_other@1"
        }
      ]
    },
    "configuration": {
      "title": "C/C++ Smart Runner",
      "properties": {
        "cpp-smart-runner.useCustomCommand": {
          "type": "boolean",
          "default": false,
          "description": "使用自訂命令（勾選後將使用下方的自訂命令設定）"
        },
        "cpp-smart-runner.customCompileCommand": {
          "type": "string",
          "default": "",
          "description": "自訂編譯命令（支援變數：$fileName, $fileNameWithoutExt, $dir, $fullFileName）留空則根據語言自動選擇 gcc/g++",
          "examples": [
            "gcc \"$fullFileName\" -o \"$dir/$fileNameWithoutExt\""
          ]
        },
        "cpp-smart-runner.customRunCommand": {
          "type": "string",
          "default": "\"$dir/$fileNameWithoutExt.exe\"",
          "description": "自訂執行命令（支援變數：$fileName, $fileNameWithoutExt, $dir, $fullFileName）",
          "examples": [
            "\"$dir/$fileNameWithoutExt\""
          ]
        },
        "cpp-smart-runner.compilerPath": {
          "type": "string",
          "default": "",
          "description": "編譯器路徑 (留空則自動偵測 gcc/g++)"
        },
        "cpp-smart-runner.compilerFlags": {
          "type": "string",
          "default": "-Wall -O2",
          "description": "編譯器額外參數（通用參數，語言標準由程式自動判斷）"
        },
        "cpp-smart-runner.cStandard": {
          "type": "string",
          "default": "-std=c11",
          "description": "C 語言標準（預設：-std=c11）",
          "examples": [
            "-std=c99",
            "-std=c11",
            "-std=c17",
            "-std=c2x"
          ]
        },
        "cpp-smart-runner.cppStandard": {
          "type": "string",
          "default": "-std=c++11",
          "description": "C++ 語言標準（預設：-std=c++11）",
          "examples": [
            "-std=c++11",
            "-std=c++14",
            "-std=c++17",
            "-std=c++20",
            "-std=c++23"
          ]
        },
        "cpp-smart-runner.outputDir": {
          "type": "string",
          "default": "",
          "description": "輸出目錄 (留空則與原始檔同目錄)"
        },
        "cpp-smart-runner.clearTerminal": {
          "type": "boolean",
          "default": true,
          "description": "執行前清除終端機"
        },
        "cpp-smart-runner.saveBeforeCompile": {
          "type": "boolean",
          "default": true,
          "description": "編譯前自動儲存檔案"
        },
        "cpp-smart-runner.showExecutionMessage": {
          "type": "boolean",
          "default": true,
          "description": "顯示執行訊息"
        },
        "cpp-smart-runner.autoConvertEncoding": {
          "type": "boolean",
          "default": true,
          "description": "編譯前自動偵測並轉換 ANSI/Big5 檔案為 UTF-8"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npm run compile && npm test"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.x",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.0.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "sinon": "^17.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  }
}
