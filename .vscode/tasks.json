{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "compile",
			"problemMatcher": "$tsc",
			"group": "build",
			"label": "npm: compile"
		},
		{
			"type": "npm",
			"script": "test",
			"problemMatcher": [],
			"group": "test",
			"label": "npm: test"
		},
		{
			"label": "Compile TypeScript",
			"type": "shell",
			"command": "Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process; npm run compile",
			"group": "build"
		},
		{
			"label": "Run Tests",
			"type": "shell",
			"command": "Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process; npm test",
			"group": "test"
		}
	]
}